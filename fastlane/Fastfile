default_platform(:ios)

platform :ios do
  desc "Resolve Swift packages and build the app without code signing"
  lane :verify_spm_build do
    build_app(
      project: "TestBinaryApp.xcodeproj",
      scheme: "TestBinaryApp",
      configuration: "Debug",
      destination: "generic/platform=iOS Simulator",
      derived_data_path: "./DerivedData",
      clean: true,
      skip_package_dependencies_resolution: false,
      skip_profile_detection: true,
      skip_archive: true,
      xcargs: "CODE_SIGNING_ALLOWED=NO CODE_SIGNING_REQUIRED=NO"
    )
  end
end
